# Ignore the data directory, except the permanent per-round prediction
# archive (data/site_archive/ -- see src/config.py SITE_ARCHIVE_DIR).
# NOTE: this must be /data/* (not /data) for the negation below to work --
# git cannot re-include a child of a wholesale-excluded parent directory.
/data/*
!/data/site_archive

# Ignore the virtual environment directory
/wc-predictor

# Ignore Python cache files
/src/__pycache__
/src/data/__pycache__
/src/features/__pycache__
/src/predictor/__pycache__
/src/bracket/__pycache__
/src/simulator/__pycache__

/tests/__pycache__

# Generated static site (deployed via scripts/deploy_site.sh)
/site

# Site builder cache
/src/site/__pycache__

/.pytest_cache