# Ignore the data directory, except the permanent per-round prediction
# archive (data/site_archive/ -- see src/config.py SITE_ARCHIVE_DIR) and the
# real knockout bracket (data/knockout_fixtures/ -- must be git-tracked so
# that `git pull` on the droplet picks up hand-edits as rounds resolve; the
# automated cron pipeline has no other way to see bracket updates).
# NOTE: this must be /data/* (not /data) for the negations below to work --
# git cannot re-include a child of a wholesale-excluded parent directory.
/data/*
!/data/site_archive
!/data/knockout_fixtures

# Ignore the virtual environment directory
/wc-predictor

# Ignore Python cache files
/src/__pycache__
/src/data/__pycache__
/src/features/__pycache__
/src/predictor/__pycache__
/src/bracket/__pycache__
/src/simulator/__pycache__

/tests/__pycache__

# Site builder cache
/src/site/__pycache__

/.pytest_cache
